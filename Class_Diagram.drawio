        <!-- Class: User -->
        <mxCell id="c1" value="&lt;b&gt;User&lt;/b&gt;&lt;hr&gt;&lt;div style='text-align:left;padding:4px;'&gt;- userId: int&lt;br&gt;- username: String&lt;br&gt;- email: String&lt;br&gt;- passwordHash: String&lt;br&gt;- role: String&lt;br&gt;- createdAt: DateTime&lt;/div&gt;&lt;hr&gt;&lt;div style='text-align:left;padding:4px;'&gt;+ register(): void&lt;br&gt;+ login(): AuthToken&lt;br&gt;+ logout(): void&lt;br&gt;+ getProfile(): UserProfile&lt;br&gt;+ updateProfile(): void&lt;/div&gt;" style="shape=mxgraph.unified_modeling_language.class;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;overflow=fill;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="220" height="260" as="geometry" />
        </mxCell>

        <!-- Class: Admin (inherits User) -->
